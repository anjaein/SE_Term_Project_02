<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import java.lang.String?>

<ScrollPane fx:id="root" fitToWidth="true" styleClass="scroll-clean" xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.javafx.controllers.MembersController">
    <VBox fx:id="content" spacing="20" maxWidth="1000">
        <padding>
            <Insets top="24" right="32" bottom="80" left="32"/>
        </padding>
        <HBox fx:id="header" styleClass="page-header">
            <VBox spacing="4">
                <Label text="PROJECT · MEMBERS" styleClass="eyebrow"/>
                <Label text="Team" styleClass="h1"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="8" styleClass="page-actions">
                <Button fx:id="createAccountButton" text="+ Create account" onAction="#handleCreateAccount">
                    <styleClass>
                        <String fx:value="box-button"/>
                    </styleClass>
                </Button>
                <Button fx:id="addMemberButton" text="+ Add member" onAction="#handleAddMember">
                    <styleClass>
                        <String fx:value="box-button"/>
                        <String fx:value="box-button-primary"/>
                    </styleClass>
                </Button>
            </HBox>
        </HBox>
        <Line fx:id="divider"/>
        <Label text="프로젝트 멤버와 프로젝트별 역할을 관리한다."
               wrapText="true">
            <styleClass>
                <String fx:value="hand"/>
                <String fx:value="dim"/>
            </styleClass>
        </Label>
        <FlowPane fx:id="membersGrid" hgap="16" vgap="16"/>
    </VBox>
</ScrollPane>
