<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<StackPane fx:id="root" styleClass="app-bg" xmlns:fx="http://javafx.com/fxml"
           fx:controller="ui.javafx.controllers.LoginController">
    <GridPane fx:id="grid" maxWidth="880" hgap="48" vgap="20" translateY="36" StackPane.alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints percentWidth="52"/>
            <ColumnConstraints percentWidth="48"/>
        </columnConstraints>
        <VBox fx:id="brand" spacing="14" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="SE_Term_Project_02" styleClass="eyebrow"/>
            <Label text="Issue&#10;Tracker" styleClass="display"/>
            <Label text="이슈트래커" styleClass="hand" maxWidth="380" wrapText="true"/>
        </VBox>
        <VBox fx:id="form" styleClass="card" minWidth="380" spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <HBox alignment="CENTER_LEFT">
                <Label text="Sign in" styleClass="h2"/>
            </HBox>
            <Label text="계정 정보를 입력하세요." styleClass="hand" wrapText="true"/>
            <Label text="USERNAME" styleClass="eyebrow"/>
            <TextField fx:id="usernameField" text="admin" styleClass="input"/>
            <Label text="PASSWORD" styleClass="eyebrow"/>
            <PasswordField fx:id="passwordField" text="admin123" styleClass="input"/>
            <Label fx:id="errorLabel" styleClass="error-msg" visible="false" managed="false"/>
            <Button text="Sign in  →" styleClass="btn-primary" defaultButton="true" onAction="#handleSignIn"/>
        </VBox>
    </GridPane>
</StackPane>
