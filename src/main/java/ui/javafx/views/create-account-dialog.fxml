<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" spacing="10" minWidth="460" xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.javafx.controllers.CreateAccountDialogController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    <Label text="USERNAME" styleClass="eyebrow"/>
    <TextField fx:id="usernameField" promptText="아이디" styleClass="input"/>
    <Label text="PASSWORD" styleClass="eyebrow"/>
    <PasswordField fx:id="passwordField" promptText="비밀번호" styleClass="input"/>
    <Label text="ROLE" styleClass="eyebrow"/>
    <ComboBox fx:id="roleCombo" maxWidth="Infinity"/>
</VBox>
