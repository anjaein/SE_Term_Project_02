<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import java.lang.String?>

<ScrollPane fx:id="root" fitToWidth="true" styleClass="scroll-clean" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.issuetracker.ui.controllers.MembersController">
    <VBox fx:id="content" spacing="20" maxWidth="1000">
        <padding>
            <Insets top="24" right="32" bottom="80" left="32"/>
        </padding>
        <HBox fx:id="header">
            <VBox spacing="4">
                <Label text="PROJECT · MEMBERS" styleClass="eyebrow"/>
                <Label text="Team" styleClass="h1"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="8">
                <Button fx:id="createAccountButton" text="+ Sign up" styleClass="btn-primary" onAction="#handleCreateAccount"/>
                <Button fx:id="addMemberButton" text="+ Add member" styleClass="btn-primary" onAction="#handleAddMember"/>
            </HBox>
        </HBox>
        <Line fx:id="divider"/>
        <Label text="프로젝트 멤버와 역할을 관리한다. ADMIN만 계정 생성과 멤버 추가 가능"
               wrapText="true">
            <styleClass>
                <String fx:value="hand"/>
                <String fx:value="dim"/>
            </styleClass>
        </Label>
        <FlowPane fx:id="membersGrid" hgap="16" vgap="16"/>
    </VBox>
</ScrollPane>
